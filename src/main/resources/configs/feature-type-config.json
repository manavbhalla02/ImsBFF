{
  "configKey": "IMS_FEATURE_TYPE_CONFIG_V1",
  "configName": "IMS Feature Type Config",
  "version": 1,
  "featureTypes": {
    "TKT_PAGE": {
      "type": "PAGE",
      "displayName": "Ticket Page"
    },
    "COMMENT_SECTION": {
      "type": "SECTION",
      "displayName": "Comment Section"
    },
    "SUBJECT": {
      "type": "FIELD",
      "displayName": "Subject"
    },
    "DESCRIPTION": {
      "type": "FIELD",
      "displayName": "Description"
    },
    "AUTO_TKT_RESOLUTION": {
      "type": "BUTTON",
      "displayName": "Auto Ticket Resolution"
    },
    "COMMENT_RES": {
      "type": "BUTTON",
      "displayName": "Comment Response"
    },
    "AI_SUBJECT_SUMMARY": {
      "type": "BUTTON",
      "displayName": "AI Subject Summary"
    },
    "AUTH": {
      "type": "PAGE",
      "displayName": "Authentication",
      "organizationWide": true,
      "defaultActions": ["VIEW"]
    },
    "AUTH_TYPE_BASIC": {
      "type": "CARD",
      "displayName": "Basic Authentication",
      "defaultActions": ["VIEW"]
    },
    "AUTH_TYPE_OAUTH": {
      "type": "CARD",
      "displayName": "OAuth Authentication",
      "defaultActions": ["VIEW"]
    },
    "AUTH_TYPE_SSO": {
      "type": "CARD",
      "displayName": "SSO Authentication",
      "defaultActions": ["VIEW"]
    },
    "AUTH_PROVIDER_BASIC": {
      "type": "BUTTON",
      "displayName": "Basic Provider",
      "defaultActions": ["CLICK"],
      "action": {
        "method": "POST",
        "url": "/api/v1/auth/login/basic"
      }
    },
    "AUTH_PROVIDER_GOOGLE": {
      "type": "BUTTON",
      "displayName": "Google",
      "defaultActions": ["CLICK"],
      "action": {
        "method": "GET",
        "url": "/api/v1/auth/login/oauth2/google"
      }
    },
    "AUTH_PROVIDER_GITHUB": {
      "type": "BUTTON",
      "displayName": "GitHub",
      "defaultActions": ["CLICK"],
      "action": {
        "method": "GET",
        "url": "/api/v1/auth/login/oauth2/github"
      }
    },
    "AUTH_PROVIDER_LINKEDIN": {
      "type": "BUTTON",
      "displayName": "LinkedIn",
      "defaultActions": ["CLICK"],
      "action": {
        "method": "GET",
        "url": "/api/v1/auth/login/oauth2/linkedin"
      }
    },
    "AUTH_PROVIDER_OKTA": {
      "type": "BUTTON",
      "displayName": "Okta",
      "defaultActions": ["CLICK"],
      "action": {
        "method": "GET",
        "url": "/api/v1/auth/login/sso/okta"
      }
    }
  },
  "metadata": {
    "storageModel": "Config",
    "configSource": "src/main/resources/configs/feature-type-config.json",
    "notes": [
      "This file defines backend-vended feature presentation/type metadata only.",
      "Hierarchy remains in feature-graph.json.",
      "Entitlements, selection rules, and restrictions remain in PostgreSQL.",
      "Type values are intentionally UI-oriented, such as PAGE, SECTION, FIELD, BUTTON, CARD, or MODAL."
    ]
  }
}
