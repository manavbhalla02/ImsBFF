Project ims_subscription_model {
  database_type: "PostgreSQL"
  Note: '''
Hybrid design:
1. PostgreSQL stores organization, subscription, plan, feature catalog, plan entitlements, plan-driven selection rules, feature restrictions, and organization feature selections.
2. MongoDB stores feature adjacency graph only.
3. Organization-owned employee and access taxonomy stays table-driven, not enum-driven, so each org can define its own designations, employment types, employment statuses, teams, resolver groups, and permission groups.
4. LDAP is treated as a first-class enterprise integration domain:
   - internal model remains team / resolver_group / permission_group
   - ldap_directory / ldap_group / ldap_user feed and map into that internal model
   - employee_ldap_identity separates internal person linkage from external directory accounts so multi-directory and multi-account scenarios stay possible
5. Organization access assignment policy is explicit:
   - INTERNAL => employee_permission_group / employee_resolver_group are primary assignment sources
   - LDAP => ldap_group_permission_group / ldap_group_resolver_group drive effective access through synced directory membership
   - HYBRID => LDAP is primary, while direct employee assignment can be used as an explicit override path

Feature catalog examples:
- 1 -> TKT_PAGE
- 2 -> COMMENT_SECTION
- 3 -> SUBJECT
- 4 -> DESCRIPTION
- 5 -> AUTO_TKT_RESOLUTION
- 6 -> COMMENT_RES
- 7 -> AI_SUBJECT_SUMMARY
- 8 -> AUTH
- 9 -> AUTH_TYPE_OAUTH
- 10 -> AUTH_PROVIDER_GOOGLE

MongoDB adjacency examples:
- 1 -> [2,3,4,5,7]
- 2 -> [6]
- 8 -> [9,11,12]
- 9 -> [10,13,14]
- 11 -> [15]

Selection rule examples:
- BASIC + AUTH => select exactly 1 direct child auth type
- BASIC + AUTH_TYPE_OAUTH => select exactly 1 direct child provider
- PREMIUM + AUTH => select 1 to 2 direct child auth types
- ADVANCED + AUTH => select 1 to 3 direct child auth types

Restriction examples:
- BASIC + COMMENT_SECTION => MAX_COMMENTS LTE 200 COUNT
- ADVANCED + AI_SUBJECT_SUMMARY => MAX_AI_SUMMARIES_PER_DAY LTE 500 COUNT
'''
}

Enum organization_status {
  ACTIVE
  INACTIVE
  SUSPENDED
}

Enum domain_status {
  ACTIVE
  INACTIVE
}

Enum subscription_status {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

Enum billing_period {
  MONTHLY
  YEARLY
}

Enum discount_type {
  PERCENTAGE
  FIXED
}

Enum organization_feature_selection_status {
  ACTIVE
  INACTIVE
}

Enum restriction_type {
  BOOLEAN
  NUMERIC
  TEXT
  DURATION
}

Enum restriction_operator {
  EQ
  NE
  LT
  LTE
  GT
  GTE
  IN
}

Enum restriction_unit {
  COUNT
  DAY
  MINUTE
  FLAG
  CHARACTER
  PERCENT
}

Enum selection_scope {
  DIRECT_CHILDREN
}

Enum feature_grant_type {
  DIRECT
  SELECTABLE
}

Enum ldap_identity_link_type {
  PRIMARY
  SECONDARY
  ADMIN_ACCOUNT
  SERVICE_ACCOUNT
  HISTORICAL
}

Enum organization_access_mode {
  INTERNAL
  LDAP
  HYBRID
}

Table organization {
  organization_id bigint [pk, increment]
  organization_code varchar(64) [not null, unique, note: "Stable business key, e.g. ORG_ABC123"]
  organization_name varchar(255) [not null]
  status organization_status [not null, default: 'ACTIVE']
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table organization_access_policy {
  organization_access_policy_id bigint [pk, increment]
  organization_id bigint [not null]
  access_mode organization_access_mode [not null, default: 'INTERNAL', note: "INTERNAL = direct employee assignment. LDAP = directory-derived assignment. HYBRID = LDAP primary with internal override support."]
  allow_manual_permission_assignment boolean [not null, default: true, note: "Set false for strict LDAP-only authorization management."]
  allow_manual_resolver_assignment boolean [not null, default: true, note: "Set false for strict LDAP-only operational group assignment."]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (organization_id) [unique]
  }
}

Table organization_domain {
  organization_domain_id bigint [pk, increment]
  organization_id bigint [not null]
  domain_name varchar(320) [not null, unique, note: "Globally unique domain ownership"]
  is_primary boolean [not null, default: false]
  is_verified boolean [not null, default: false]
  status domain_status [not null, default: 'ACTIVE']
  created_at timestamp [not null]
  verified_at timestamp

  indexes {
    (organization_id, is_primary)
  }
}

Table designation {
  designation_id bigint [pk, increment]
  organization_id bigint [not null]
  designation_code varchar(64) [note: "Optional stable key within an organization, e.g. SDE_1, HR_MANAGER"]
  designation_title varchar(120) [not null]
  description varchar(500)
  is_active boolean [not null, default: true]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (organization_id, designation_title) [unique]
    (organization_id, designation_code) [unique]
  }
}

Table employment_type {
  employment_type_id bigint [pk, increment]
  organization_id bigint [not null]
  type_key varchar(64) [not null, note: "Org-scoped internal key, e.g. FULL_TIME, CONTRACT, INTERN"]
  type_name varchar(120) [not null]
  description varchar(500)
  is_active boolean [not null, default: true]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (organization_id, type_key) [unique]
    (organization_id, type_name) [unique]
  }
}

Table employment_status {
  employment_status_id bigint [pk, increment]
  organization_id bigint [not null]
  status_key varchar(64) [not null, note: "Org-scoped internal key, e.g. ACTIVE, ON_NOTICE, EXITED"]
  status_name varchar(120) [not null]
  description varchar(500)
  is_active boolean [not null, default: true]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (organization_id, status_key) [unique]
    (organization_id, status_name) [unique]
  }
}

Table employee {
  employee_id bigint [pk, increment]
  organization_id bigint [not null]
  employee_code varchar(64) [not null, note: "Org-scoped employee identifier / empId"]
  designation_id bigint [not null]
  employment_type_id bigint [not null]
  employment_status_id bigint [not null]
  manager_employee_id bigint [note: "Self-reference for reporting hierarchy"]
  first_name varchar(100) [not null]
  last_name varchar(100)
  display_name varchar(200)
  work_email varchar(255) [not null, note: "Primary work email used for company/app identity flows"]
  personal_email varchar(255)
  phone_number varchar(32)
  joining_date date [not null]
  is_active boolean [not null, default: true]
  salary decimal(14,2)
  currency_code char(3) [default: 'USD']
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (organization_id, employee_code) [unique]
    (organization_id, work_email) [unique]
    (organization_id, designation_id)
    (organization_id, employment_type_id)
    (organization_id, employment_status_id)
    (organization_id, manager_employee_id)
  }
}

Table team {
  team_id bigint [pk, increment]
  organization_id bigint [not null]
  parent_team_id bigint [note: "Self-reference for hierarchical business structure"]
  team_code varchar(64) [not null, note: "Org-scoped stable key for business hierarchy nodes"]
  team_name varchar(120) [not null]
  description varchar(500)
  is_active boolean [not null, default: true]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (organization_id, team_code) [unique]
    (organization_id, team_name)
    (organization_id, parent_team_id)
  }
}

Table employee_team {
  employee_team_id bigint [pk, increment]
  employee_id bigint [not null]
  team_id bigint [not null]
  is_primary boolean [not null, default: false]
  assigned_at timestamp [not null]

  indexes {
    (employee_id, team_id) [unique]
    (team_id, is_primary)
  }
}

Table resolver_group {
  resolver_group_id bigint [pk, increment]
  organization_id bigint [not null]
  parent_resolver_group_id bigint [note: "Self-reference for hierarchical operational ownership structure"]
  resolver_group_code varchar(64) [not null, note: "Org-scoped stable key for operational hierarchy nodes"]
  resolver_group_name varchar(120) [not null]
  responsibility_scope varchar(255) [note: "Short summary of the work/accountability scope owned by this resolver group"]
  description varchar(500)
  is_active boolean [not null, default: true]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (organization_id, resolver_group_code) [unique]
    (organization_id, resolver_group_name)
    (organization_id, parent_resolver_group_id)
  }
}

Table employee_resolver_group {
  employee_resolver_group_id bigint [pk, increment]
  employee_id bigint [not null]
  resolver_group_id bigint [not null]
  is_primary boolean [not null, default: false]
  assigned_at timestamp [not null]

  indexes {
    (employee_id, resolver_group_id) [unique]
    (resolver_group_id, is_primary)
  }
}

Table permission_group {
  permission_group_id bigint [pk, increment]
  organization_id bigint [not null]
  parent_permission_group_id bigint [note: "Self-reference for hierarchical access bundle structure"]
  permission_group_code varchar(64) [not null, note: "Org-scoped stable key for reusable hierarchical access bundles"]
  permission_group_name varchar(120) [not null, note: "Display name can repeat across different branches but should stay unique within the same parent scope"]
  description varchar(500)
  is_active boolean [not null, default: true]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (organization_id, permission_group_code) [unique]
    (organization_id, parent_permission_group_id, permission_group_name) [unique]
    (organization_id, parent_permission_group_id)
  }
}

Table employee_permission_group {
  employee_permission_group_id bigint [pk, increment]
  employee_id bigint [not null]
  permission_group_id bigint [not null]
  assigned_at timestamp [not null]

  indexes {
    (employee_id, permission_group_id) [unique]
  }
}

Table feature {
  feature_id bigint [pk, increment]
  feature_key varchar(80) [not null, unique, note: "Examples: TKT_PAGE, COMMENT_SECTION, AUTH, AUTH_TYPE_OAUTH, AUTH_PROVIDER_GOOGLE"]
  feature_name varchar(120) [not null]
  description varchar(500)
  is_active boolean [not null, default: true]
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table feature_permission {
  feature_permission_id bigint [pk, increment]
  feature_id bigint [not null]
  permission_key varchar(64) [not null, note: "Action key on a feature, e.g. VIEW, EDIT, CONFIGURE, APPROVE, UPLOAD"]
  permission_name varchar(120) [not null]
  description varchar(500)
  is_active boolean [not null, default: true]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (feature_id, permission_key) [unique]
  }
}

Table permission_group_feature_permission {
  permission_group_feature_permission_id bigint [pk, increment]
  permission_group_id bigint [not null]
  feature_permission_id bigint [not null]
  granted_at timestamp [not null]

  indexes {
    (permission_group_id, feature_permission_id) [unique]
  }
}

Table ldap_directory {
  ldap_directory_id bigint [pk, increment]
  organization_id bigint [not null]
  directory_code varchar(64) [not null, note: "Org-scoped stable key for enterprise directory source"]
  directory_name varchar(120) [not null]
  directory_type varchar(64) [not null, note: "Examples: LDAP, ACTIVE_DIRECTORY, AZURE_AD_SYNC"]
  base_dn varchar(255)
  server_uri varchar(255)
  is_active boolean [not null, default: true]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (organization_id, directory_code) [unique]
    (organization_id, directory_name) [unique]
  }
}

Table ldap_group {
  ldap_group_id bigint [pk, increment]
  ldap_directory_id bigint [not null]
  parent_ldap_group_id bigint [note: "Self-reference for hierarchical enterprise directory groups"]
  external_group_key varchar(128) [note: "Stable external identifier when available"]
  group_dn varchar(255) [not null, note: "Distinguished name from directory"]
  group_name varchar(120) [not null]
  description varchar(500)
  is_active boolean [not null, default: true]
  synced_at timestamp
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (ldap_directory_id, group_dn) [unique]
    (ldap_directory_id, external_group_key) [unique]
    (ldap_directory_id, group_name)
    (ldap_directory_id, parent_ldap_group_id)
  }
}

Table ldap_user {
  ldap_user_id bigint [pk, increment]
  ldap_directory_id bigint [not null]
  external_user_key varchar(128) [note: "Stable external directory identifier when available"]
  user_dn varchar(255) [not null, note: "Distinguished name from directory"]
  username varchar(120) [not null]
  work_email varchar(255)
  display_name varchar(200)
  is_active boolean [not null, default: true]
  synced_at timestamp
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (ldap_directory_id, user_dn) [unique]
    (ldap_directory_id, external_user_key) [unique]
    (ldap_directory_id, username)
    (ldap_directory_id, work_email)
  }
}

Table employee_ldap_identity {
  employee_ldap_identity_id bigint [pk, increment]
  employee_id bigint [not null]
  ldap_user_id bigint [not null]
  link_type ldap_identity_link_type [not null]
  is_primary boolean [not null, default: false, note: "One active primary link per employee should be enforced in implementation with a partial unique index if required"]
  linked_at timestamp [not null]
  unlinked_at timestamp
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (employee_id, ldap_user_id) [unique]
    (ldap_user_id) [unique]
    (employee_id, is_primary)
  }
}

Table ldap_user_group {
  ldap_user_group_id bigint [pk, increment]
  ldap_user_id bigint [not null]
  ldap_group_id bigint [not null]
  synced_at timestamp [not null]

  indexes {
    (ldap_user_id, ldap_group_id) [unique]
  }
}

Table ldap_group_permission_group {
  ldap_group_permission_group_id bigint [pk, increment]
  ldap_group_id bigint [not null]
  permission_group_id bigint [not null]
  mapped_at timestamp [not null]

  indexes {
    (ldap_group_id, permission_group_id) [unique]
  }
}

Table ldap_group_team {
  ldap_group_team_id bigint [pk, increment]
  ldap_group_id bigint [not null]
  team_id bigint [not null]
  mapped_at timestamp [not null]

  indexes {
    (ldap_group_id, team_id) [unique]
  }
}

Table ldap_group_resolver_group {
  ldap_group_resolver_group_id bigint [pk, increment]
  ldap_group_id bigint [not null]
  resolver_group_id bigint [not null]
  mapped_at timestamp [not null]

  indexes {
    (ldap_group_id, resolver_group_id) [unique]
  }
}

Table plan {
  plan_id bigint [pk, increment]
  plan_code varchar(40) [not null, unique, note: "BASIC, PREMIUM, ADVANCED"]
  plan_name varchar(120) [not null]
  billing_period billing_period [not null, default: 'MONTHLY']
  base_price decimal(12,2) [not null]
  currency_code char(3) [not null, default: 'USD']
  is_active boolean [not null, default: true]
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table plan_feature {
  plan_feature_id bigint [pk, increment]
  plan_id bigint [not null]
  feature_id bigint [not null, note: "Feature granted at the plan level. DIRECT means auto-granted. SELECTABLE means the org must choose descendants/config under this feature."]
  grant_type feature_grant_type [not null, default: 'DIRECT', note: "DIRECT = auto-granted by plan. SELECTABLE = org must choose within this granted feature family."]
  created_at timestamp [not null]

  indexes {
    (plan_id, feature_id) [unique]
  }
}

Table plan_feature_selection_rule {
  plan_feature_selection_rule_id bigint [pk, increment]
  plan_feature_id bigint [not null]
  applies_to_feature_id bigint [not null, note: "Node whose direct children can be selected. Can be the entitlement anchor or a descendant node inside the granted subtree."]
  selection_scope selection_scope [not null, default: 'DIRECT_CHILDREN']
  min_selectable int [not null, default: 0]
  max_selectable int [not null]
  selection_required boolean [not null, default: false]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (plan_feature_id, applies_to_feature_id, selection_scope) [unique]
  }
}

Table plan_feature_restriction {
  plan_feature_restriction_id bigint [pk, increment]
  plan_feature_id bigint [not null]
  restriction_key varchar(80) [not null, note: "Examples: MAX_COMMENTS, VIEW_ACCESS, MAX_AI_SUMMARIES_PER_DAY"]
  restriction_type restriction_type [not null]
  operator restriction_operator [not null]
  restriction_value varchar(255) [not null, note: "Stored as text so boolean, numeric, and text restrictions share one model"]
  restriction_unit restriction_unit
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (plan_feature_id, restriction_key) [unique]
  }
}

Table organization_feature_selection {
  organization_feature_selection_id bigint [pk, increment]
  organization_id bigint [not null]
  feature_id bigint [not null, note: "Selected feature for current organization setup, e.g. AUTH_TYPE_OAUTH or AUTH_PROVIDER_GOOGLE"]
  status organization_feature_selection_status [not null, default: 'ACTIVE']
  selected_at timestamp [not null]

  indexes {
    (organization_id, feature_id) [unique]
    (organization_id, status)
  }
}

Table subscription {
  subscription_id bigint [pk, increment]
  organization_id bigint [not null]
  plan_id bigint [not null]
  start_at timestamp [not null]
  end_at timestamp
  status subscription_status [not null, default: 'PENDING']
  auto_renew boolean [not null, default: true]
  cancelled_at timestamp
  termination_reason varchar(255)
  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (organization_id, status, start_at, end_at)
  }
}

Table coupon {
  coupon_id bigint [pk, increment]
  coupon_code varchar(64) [not null, unique]
  discount_type discount_type [not null]
  discount_value decimal(12,2) [not null, note: "Percent or fixed amount based on discount_type"]
  valid_from timestamp [not null]
  valid_to timestamp
  max_redemptions int
  is_active boolean [not null, default: true]
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table coupon_plan {
  coupon_plan_id bigint [pk, increment]
  coupon_id bigint [not null]
  plan_id bigint [not null]
  created_at timestamp [not null]

  indexes {
    (coupon_id, plan_id) [unique]
  }
}

Table subscription_coupon {
  subscription_coupon_id bigint [pk, increment]
  subscription_id bigint [not null]
  coupon_id bigint [not null]
  applied_discount_value decimal(12,2) [not null]
  applied_at timestamp [not null]

  indexes {
    (subscription_id, coupon_id) [unique]
  }
}

Ref: organization_domain.organization_id > organization.organization_id
Ref: organization_access_policy.organization_id > organization.organization_id
Ref: designation.organization_id > organization.organization_id
Ref: employment_type.organization_id > organization.organization_id
Ref: employment_status.organization_id > organization.organization_id
Ref: employee.organization_id > organization.organization_id
Ref: employee.designation_id > designation.designation_id
Ref: employee.employment_type_id > employment_type.employment_type_id
Ref: employee.employment_status_id > employment_status.employment_status_id
Ref: employee.manager_employee_id > employee.employee_id
Ref: team.organization_id > organization.organization_id
Ref: team.parent_team_id > team.team_id
Ref: employee_team.employee_id > employee.employee_id
Ref: employee_team.team_id > team.team_id
Ref: resolver_group.organization_id > organization.organization_id
Ref: resolver_group.parent_resolver_group_id > resolver_group.resolver_group_id
Ref: employee_resolver_group.employee_id > employee.employee_id
Ref: employee_resolver_group.resolver_group_id > resolver_group.resolver_group_id
Ref: permission_group.organization_id > organization.organization_id
Ref: permission_group.parent_permission_group_id > permission_group.permission_group_id
Ref: employee_permission_group.employee_id > employee.employee_id
Ref: employee_permission_group.permission_group_id > permission_group.permission_group_id
Ref: feature_permission.feature_id > feature.feature_id
Ref: permission_group_feature_permission.permission_group_id > permission_group.permission_group_id
Ref: permission_group_feature_permission.feature_permission_id > feature_permission.feature_permission_id
Ref: ldap_directory.organization_id > organization.organization_id
Ref: ldap_group.ldap_directory_id > ldap_directory.ldap_directory_id
Ref: ldap_group.parent_ldap_group_id > ldap_group.ldap_group_id
Ref: ldap_user.ldap_directory_id > ldap_directory.ldap_directory_id
Ref: employee_ldap_identity.employee_id > employee.employee_id
Ref: employee_ldap_identity.ldap_user_id > ldap_user.ldap_user_id
Ref: ldap_user_group.ldap_user_id > ldap_user.ldap_user_id
Ref: ldap_user_group.ldap_group_id > ldap_group.ldap_group_id
Ref: ldap_group_permission_group.ldap_group_id > ldap_group.ldap_group_id
Ref: ldap_group_permission_group.permission_group_id > permission_group.permission_group_id
Ref: ldap_group_team.ldap_group_id > ldap_group.ldap_group_id
Ref: ldap_group_team.team_id > team.team_id
Ref: ldap_group_resolver_group.ldap_group_id > ldap_group.ldap_group_id
Ref: ldap_group_resolver_group.resolver_group_id > resolver_group.resolver_group_id
Ref: plan_feature.plan_id > plan.plan_id
Ref: plan_feature.feature_id > feature.feature_id
Ref: plan_feature_selection_rule.plan_feature_id > plan_feature.plan_feature_id
Ref: plan_feature_selection_rule.applies_to_feature_id > feature.feature_id
Ref: plan_feature_restriction.plan_feature_id > plan_feature.plan_feature_id
Ref: organization_feature_selection.organization_id > organization.organization_id
Ref: organization_feature_selection.feature_id > feature.feature_id
Ref: subscription.organization_id > organization.organization_id
Ref: subscription.plan_id > plan.plan_id
Ref: coupon_plan.coupon_id > coupon.coupon_id
Ref: coupon_plan.plan_id > plan.plan_id
Ref: subscription_coupon.subscription_id > subscription.subscription_id
Ref: subscription_coupon.coupon_id > coupon.coupon_id
